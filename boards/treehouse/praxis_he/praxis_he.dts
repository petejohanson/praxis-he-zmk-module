/dts-v1/;
#include <st/f4/stm32f411Xe.dtsi>
#include <st/f4/stm32f411c(c-e)ux-pinctrl.dtsi>

#include <zephyr/dt-bindings/dt-util.h>
#include <dt-bindings/led/led.h>

#include <dt-bindings/zmk/matrix_transform.h>
#include <physical_layouts.dtsi>

/ {
	model = "Treehouse Praxis HE";
	compatible = "treehouse,praxis-he";

	chosen {
		zephyr,sram = &sram0;
		zephyr,flash = &flash0;
		zephyr,boot-mode = &retention0;
		/* Disabled until upstream driver is available
		zmk,underglow = &led_strip;
		*/
	};

	aliases {
		volt-sensor0 = &vref;
		volt-sensor1 = &vbat;
	};

	mux: mux {
		compatible = "zmk,gpio-mux";
		
		select-gpios
		    = <&gpiob 14 GPIO_ACTIVE_HIGH>
		    , <&gpiob 13 GPIO_ACTIVE_HIGH>
		    , <&gpiob 10 GPIO_ACTIVE_HIGH>
		    , <&gpiob 1  GPIO_ACTIVE_HIGH>
		    ;
		
		en-gpios = <&gpiob 12 GPIO_ACTIVE_LOW>;
		
		gpio-controller;
		ngpios = <16>;
		#gpio-cells = <2>;
	};

	matrix: matrix {
		compatible = "zmk,kscan-he-matrix";
		skip-startup-calibration;
		active-polling-interval-ms = <0>;

		select-gpios
			= <&mux 0 0>
			, <&mux 1 0>
			, <&mux 2 0>
			, <&mux 3 0>
			, <&mux 4 0>
			, <&mux 5 0>
			, <&mux 6 0>
			, <&mux 7 0>
			, <&mux 8 0>
			, <&mux 9 0>
			, <&mux 10 0>
			, <&mux 11 0>
			, <&mux 12 0>
			, <&mux 13 0>
			, <&mux 14 0>
			;
		io-channels = <&adc1 0 &adc1 1 &adc1 2 &adc1 3 &adc1 4>;
		channel-select-masks = <0>, <0>, <0>, <(BIT(0))>, <(BIT(0) + BIT(1) + BIT(2) + BIT(7) + BIT(9) + BIT(11) + BIT(12) + BIT(13))>;
		high-threshold-noise-mult = <3>;
	};

	transform: transform {
		compatible = "zmk,matrix-transform";
		rows = <5>;
		columns = <15>;
		
		map = <
		  RC(0,7) RC(0,6) RC(0,5)  RC(0,4) RC(0,3) RC(0,2) RC(0,1) RC(0,0)           RC(0,14) RC(0,13) RC(0,12) RC(0,11) RC(0,10) RC(0,9) RC(0,8)   RC(2,8)
		 RC(1,6)  RC(1,5) RC(1,4) RC(1,3) RC(1,2) RC(1,1) RC(1,0)              RC(1,14) RC(1,13) RC(1,12) RC(1,11) RC(1,10) RC(1,9) RC(1,8)  RC(1,7)
		RC(2,6)  RC(2,5) RC(2,4) RC(2,3) RC(2,2) RC(2,1) RC(2,0)                RC(2,14) RC(2,13) RC(2,12) RC(2,11) RC(2,10) RC(2,9)     RC(2,7)
		          RC(3,6) RC(3,5) RC(3,4) RC(3,3) RC(3,2) RC(3,1)             RC(3,12) RC(3,11) RC(3,10) RC(3,9) RC(3,8) RC(3,7) RC(3,13) RC(3,14)
		        RC(4,5)           RC(4,6)     RC(4,4)      RC(4,3)                           RC(4,8) RC(4,10) RC(4,14)
		>;
    };

	layout: layout {
		compatible = "zmk,physical-layout";
		display-name = "Standard";
		transform = <&transform>;
		kscan = <&matrix>;
		keys  //                     w   h    x    y     rot    rx    ry
		   = <&key_physical_attrs 100 100   50   13       0     0     0>
		   , <&key_physical_attrs 100 100  175   25       0     0     0>
		   , <&key_physical_attrs 100 100  275   25       0     0     0>
		   , <&key_physical_attrs 100 100  375   13       0     0     0>
		   , <&key_physical_attrs 100 100  475   25    1200   475   125>
		   , <&key_physical_attrs 100 100  575   25    1200   475   125>
		   , <&key_physical_attrs 100 100  675   25    1200   475   125>
		   , <&key_physical_attrs 100 100  775   25    1200   475   125>
		   , <&key_physical_attrs 100 100  950    0 (-1200)  1400   100>
		   , <&key_physical_attrs 100 100 1050    0 (-1200)  1400   100>
		   , <&key_physical_attrs 100 100 1150    0 (-1200)  1400   100>
		   , <&key_physical_attrs 100 100 1250    0 (-1200)  1400   100>
		   , <&key_physical_attrs 100 100 1350   13       0     0     0>
		   , <&key_physical_attrs 100 100 1450   25       0     0     0>
		   , <&key_physical_attrs 100 100 1550   25       0     0     0>
		   , <&key_physical_attrs 100 100 1650   25       0     0     0>
		   , <&key_physical_attrs 100 100   25  113       0     0     0>
		   , <&key_physical_attrs 150 100  150  125       0     0     0>
		   , <&key_physical_attrs 100 100  300  125       0     0     0>
		   , <&key_physical_attrs 100 100  425  125    1200   475   125>
		   , <&key_physical_attrs 100 100  525  125    1200   475   125>
		   , <&key_physical_attrs 100 100  625  125    1200   475   125>
		   , <&key_physical_attrs 100 100  725  125    1200   475   125>
		   , <&key_physical_attrs 100 100  900  100 (-1200)  1400   100>
		   , <&key_physical_attrs 100 100 1000  100 (-1200)  1400   100>
		   , <&key_physical_attrs 100 100 1100  100 (-1200)  1400   100>
		   , <&key_physical_attrs 100 100 1200  100 (-1200)  1400   100>
		   , <&key_physical_attrs 100 100 1325  113       0     0     0>
		   , <&key_physical_attrs 100 100 1425  125       0     0     0>
		   , <&key_physical_attrs 100 100 1525  125       0     0     0>
		   , <&key_physical_attrs 150 100 1625  125       0     0     0>
		   , <&key_physical_attrs 100 100    0  213       0     0     0>
		   , <&key_physical_attrs 175 100  125  225       0     0     0>
		   , <&key_physical_attrs 100 100  300  225       0     0     0>
		   , <&key_physical_attrs 100 100  450  225    1200   475   125>
		   , <&key_physical_attrs 100 100  550  225    1200   475   125>
		   , <&key_physical_attrs 100 100  650  225    1200   475   125>
		   , <&key_physical_attrs 100 100  750  225    1200   475   125>
		   , <&key_physical_attrs 100 100  925  200 (-1200)  1400   100>
		   , <&key_physical_attrs 100 100 1025  200 (-1200)  1400   100>
		   , <&key_physical_attrs 100 100 1125  200 (-1200)  1400   100>
		   , <&key_physical_attrs 100 100 1225  200 (-1200)  1400   100>
		   , <&key_physical_attrs 100 100 1375  225       0     0     0>
		   , <&key_physical_attrs 100 100 1475  225       0     0     0>
		   , <&key_physical_attrs 225 100 1575  225       0     0     0>
		   , <&key_physical_attrs 225 100  100  325       0     0     0>
		   , <&key_physical_attrs 100 100  325  325       0     0     0>
		   , <&key_physical_attrs 100 100  500  325    1200   475   125>
		   , <&key_physical_attrs 100 100  600  325    1200   475   125>
		   , <&key_physical_attrs 100 100  700  325    1200   475   125>
		   , <&key_physical_attrs 100 100  800  325    1200   475   125>
		   , <&key_physical_attrs 100 100  875  300 (-1200)  1400   100>
		   , <&key_physical_attrs 100 100  975  300 (-1200)  1400   100>
		   , <&key_physical_attrs 100 100 1075  300 (-1200)  1400   100>
		   , <&key_physical_attrs 100 100 1175  300 (-1200)  1400   100>
		   , <&key_physical_attrs 100 100 1350  325       0     0     0>
		   , <&key_physical_attrs 100 100 1450  325       0     0     0>
		   , <&key_physical_attrs 175 100 1550  325       0     0     0>
		   , <&key_physical_attrs 100 100 1725  325       0     0     0>
		   , <&key_physical_attrs 150 100  100  425       0     0     0>
		   , <&key_physical_attrs 150 100  475  437    1200   475   125>
		   , <&key_physical_attrs 225 100  625  425    1200   475   125>
		   , <&key_physical_attrs 100 100  850  425    1200   475   125>
		   , <&key_physical_attrs 275 100  875  400 (-1200)  1400   100>
		   , <&key_physical_attrs 150 100 1150  413 (-1200)  1400   100>
		   , <&key_physical_attrs 150 100 1600  425       0     0     0>
		   ;
	};
};

&usart1 {
	pinctrl-0 = <&usart1_tx_pa9 &usart1_rx_pa10>;
	pinctrl-names = "default";
	current-speed = <115200>;
};

#if 0

&timers1 {
	status = "okay";

	led_pwm: pwm {
		status = "okay";
		pinctrl-0 = <&tim1_ch3n_pb15>;
		pinctrl-names = "default";
	};
};

/ {
	led_strip: ws2812 {
		compatible = "worldsemi,ws2812-stm32-timer";
		pwms = <&led_pwm 3 0 (PWM_POLARITY_NORMAL | STM32_PWM_COMPLEMENTARY)>;
		dmas = <&dma2 6 6 (STM32_DMA_PERIPH_TX | STM32_DMA_MEM_16BITS | STM32_DMA_PERIPH_16BITS) STM32_DMA_FIFO_FULL>;
		dma-names = "tx";

		/* WS2812 */
		code-period-ns = <1500>;
		reset-codes = <70>;
		zero-high-ns = <320>;
		one-high-ns = <640>;
		chain-length = <3>;
		color-mapping = <LED_COLOR_ID_GREEN
				 LED_COLOR_ID_RED
				 LED_COLOR_ID_BLUE>;
	};
};

#endif

&spi1 {
	pinctrl-0 = <&spi1_mosi_pa7 &spi1_miso_pa6 &spi1_sck_pa5>;
	cs-gpios = <&gpiob 0 GPIO_ACTIVE_LOW>;
	pinctrl-names = "default";
	status = "okay";

	w25q128jvs: w25q128jvs@0 {
		compatible = "jedec,spi-nor";
		/* 134217728 bits = 16 Mbytes */
		size = <DT_SIZE_M(16)>;
		reg = <0>;
		/* Fastest clock we can do on F411, fPCLK/2 */
		spi-max-frequency = <DT_FREQ_M(24)>;
		jedec-id = [ef 40 18];
		status = "okay";

		partitions {
			compatible = "fixed-partitions";
			#address-cells = <1>;
			#size-cells = <1>;

			storage_partition: partition@0 {
				label = "storage";
				reg = <0x00000000 DT_SIZE_M(8)>;
			};
		};
	};
};

zephyr_udc0: &usbotg_fs {
	pinctrl-0 = <&usb_otg_fs_dm_pa11 &usb_otg_fs_dp_pa12>;
	pinctrl-names = "default";
	status = "okay";
};

&dma2 {
	status = "okay";
};

&adc1 {
	pinctrl-0 = <&adc1_in0_pa0 &adc1_in1_pa1 &adc1_in2_pa2 &adc1_in3_pa3 &adc1_in4_pa4>;
	pinctrl-names = "default";

	dmas = <&dma2 0 0 (STM32_DMA_PERIPH_RX |  STM32_DMA_MEM_16BITS | STM32_DMA_PERIPH_16BITS) STM32_DMA_FIFO_FULL>;
	dma-names = "dma";

	st,adc-clock-source = "SYNC";
	st,adc-prescaler = <4>;
	status = "okay";

	#address-cells = <1>;
	#size-cells = <0>;

	channel@0 {
		reg = <0>;
		zephyr,gain = "ADC_GAIN_1";
		zephyr,reference = "ADC_REF_INTERNAL";
		zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
		zephyr,resolution = <12>;
	};

	channel@1 {
		reg = <1>;
		zephyr,gain = "ADC_GAIN_1";
		zephyr,reference = "ADC_REF_INTERNAL";
		zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
		zephyr,resolution = <12>;
	};

	channel@2 {
		reg = <2>;
		zephyr,gain = "ADC_GAIN_1";
		zephyr,reference = "ADC_REF_INTERNAL";
		zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
		zephyr,resolution = <12>;
	};

	channel@3 {
		reg = <3>;
		zephyr,gain = "ADC_GAIN_1";
		zephyr,reference = "ADC_REF_INTERNAL";
		zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
		zephyr,resolution = <12>;
	};

	channel@4 {
		reg = <4>;
		zephyr,gain = "ADC_GAIN_1";
		zephyr,reference = "ADC_REF_INTERNAL";
		zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
		zephyr,resolution = <12>;
	};
};

&clk_lsi {
	status = "okay";
};

&clk_hse {
	clock-frequency = <DT_FREQ_M(8)>;
	status = "okay";
};

&pll {
	div-m = <4>;
	mul-n = <96>;
	div-p = <2>;
	div-q = <4>;
	clocks = <&clk_hse>;
	status = "okay";
};

&rcc {
	clocks = <&pll>;
	clock-frequency = <DT_FREQ_M(96)>;
	ahb-prescaler = <1>;
	apb1-prescaler = <2>;
	apb2-prescaler = <1>;
};

&rtc {
	clocks = <&rcc STM32_CLOCK_BUS_APB1 0x10000000>,
		 <&rcc STM32_SRC_LSI RTC_SEL(2)>;
	status = "okay";

	backup_regs {
		status = "okay";
	};
};

&bbram {
	status = "okay";

	retainedmem0: retainedmem {
		compatible = "zephyr,retained-bbram";
		status = "okay";
                #address-cells = <1>;
                #size-cells = <1>;

                retention0: retention@0 {
                        compatible = "zephyr,retention";
                        status = "okay";
                        reg = <0x0 0x1>;
                };
	};
};
